generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH MODELS ============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  videos        Video[]
  briefs        Brief[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============ BUSINESS MODELS ============

model Conversation {
  id        String             @id @default(cuid())
  userId    String
  title     String?
  status    ConversationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  brief    Brief?
  video    Video?

  @@index([userId])
  @@map("conversations")
}

enum ConversationStatus {
  ACTIVE
  BRIEF_READY
  GENERATING
  COMPLETED
  FAILED
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

model Brief {
  id             String  @id @default(cuid())
  conversationId String  @unique
  userId         String

  videoType      String?
  businessName   String?
  industry       String?
  businessDesc   String? @db.Text
  logoUrl        String?
  brandColors    Json?
  style          String?
  targetAudience String? @db.Text
  videoLength    Int?
  mood           String?
  additionalNotes String? @db.Text

  generatedPrompt String? @db.Text

  isConfirmed  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos       Video[]      @relation("BriefVideos")

  @@index([userId])
  @@map("briefs")
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Video {
  id             String      @id @default(cuid())
  conversationId String?     @unique
  briefId        String?
  userId         String

  runwayTaskId   String?     @unique
  status         VideoStatus @default(PENDING)

  prompt         String?     @db.Text
  model          String?
  duration       Int?
  ratio          String?

  videoUrl       String?
  thumbnailUrl   String?

  errorMessage   String?     @db.Text

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  completedAt    DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  brief        Brief?        @relation("BriefVideos", fields: [briefId], references: [id])

  @@index([userId])
  @@index([runwayTaskId])
  @@map("videos")
}
