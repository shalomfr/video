# Database Configuration
# ------------------------------
# Local development: SQLite (no setup required)
DATABASE_URL="file:./dev.db"

# Production (Render): PostgreSQL
# DATABASE_URL will be automatically set by Render when you attach a PostgreSQL database


# Auth.js Configuration
# ------------------------------
NEXTAUTH_URL="http://localhost:3000"
# For production, set to your deployment URL: https://your-app.onrender.com

# Generate a secure secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"


# Google OAuth (Optional)
# ------------------------------
# Leave commented out if you don't want to use Google login
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"


# OpenRouter API (Required for AI chat)
# ------------------------------
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"


# Runway ML API (For short videos: 5-10 seconds)
# ------------------------------
# Get your API key from: https://runwayml.com/account
# Note: The app will work without this key, but short video generation will fail
RUNWAYML_API_SECRET=""


# Google AI Studio (For long videos with Gemini + Veo 3.1)
# ------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
# Used for: Scene planning (Gemini), Video generation (Veo 3.1), Quality analysis
GOOGLE_AI_API_KEY=""


# Notes:
# ------------------------------
# - Logo uploads save directly to public/uploads/logos/ (no external service needed)
# - For local development: SQLite (file:./dev.db) - run: npx prisma db push
# - For production (Render): PostgreSQL - migrations run automatically during deployment
